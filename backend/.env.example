PORT=3001
NODE_ENV=production

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=smart_scribe
DB_PASSWORD=change_me
DB_NAME=smart_scribe

JWT_SECRET=replace_with_a_long_random_string
AI_KEY_ENCRYPTION_SECRET=replace_with_another_long_random_string
ADMIN_PASSWORD=replace_with_admin_password

# 生产环境请改成前端实际访问域名，多个来源用英文逗号分隔
CORS_ORIGINS=https://your-domain.com

# 部署在 Nginx/Caddy 等反向代理后时建议开启
TRUST_PROXY=true

# 可选：服务端默认 AI 密钥；用户在设置页保存的对应服务商密钥会加密入库并优先使用
DASHSCOPE_API_KEY=
GLM_AI_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# 深度思考由用户在设置页开关控制（默认关闭）；此环境变量已废弃，保留仅为兼容旧部署
# AI_ENABLE_THINKING=false

#管理员密钥
ADMIN_BOOTSTRAP_KEY=