{
  "name": "smart-scribe-backend",
  "version": "1.0.0",
  "description": "AI 网文生成工具后端",
  "main": "dist/backend/src/app.js",
  "scripts": {
    "start": "node dist/backend/src/app.js",
    "dev": "tsx watch src/app.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "db:init": "tsx scripts/initDb.ts",
    "db:migrate:rbac-usage": "tsx scripts/migrateRbacUsage.ts",
    "db:migrate:novel-memory": "tsx scripts/migrateNovelMemory.ts",
    "db:migrate:ai-credential": "tsx scripts/migrateAiCredential.ts",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.9.1",
    "sequelize": "^6.35.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/express-serve-static-core": "^4.19.8",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.3",
    "@types/supertest": "^7.2.0",
    "babel-jest": "^30.4.1",
    "jest": "^30.3.0",
    "nodemon": "^3.0.2",
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
